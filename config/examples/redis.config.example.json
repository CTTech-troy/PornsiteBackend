{
  "provider": "upstash",
  "requiredEnv": [
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN"
  ],
  "cache": {
    "defaultTtlSeconds": 30,
    "apiMetricsTtlSeconds": 10,
    "moderationStateTtlSeconds": 3600
  },
  "queues": {
    "prefix": "xstream",
    "enterpriseImportPrefix": "xstream:enterprise-import",
    "deadLetterPrefix": "xstream:enterprise-import:dead-letter",
    "memoryFallback": false
  }
}

