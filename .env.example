# =============================================================================
# backend/.env.example
#
# Copy this file to backend/.env and fill in your real values.
# Never commit backend/.env to version control.
# =============================================================================

# Server
NODE_ENV=development
PORT=5043

# CORS — comma-separated list of allowed frontend origins
# Local:      http://localhost:5173
# Production: https://yourapp.netlify.app
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Payment service connection
# The backend delegates ALL checkout creation to the C# payment service.
# Only webhook signature verification uses the keys below.
#
# Local:      http://localhost:5001  (matches PAYMENT_SERVICE_PORT in paymentSystem/.env)
# Production: https://your-payment-service.onrender.com
# -----------------------------------------------------------------------------
PAYMENT_SERVICE_URL=http://localhost:5001

# Paystack secret key — used ONLY for webhook HMAC signature verification
# and for re-querying transactions server-side after a webhook fires.
# Get from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_...

# Monnify secrets — used ONLY for webhook HMAC verification and server-side
# transaction re-query. Checkout credentials live in paymentSystem/.env.
# Get from: https://app.monnify.com/developer
MONNIFY_API_KEY=MK_TEST_...
MONNIFY_SECRET_KEY=...
MONNIFY_BASE_URL=https://sandbox.monnify.com

# Platform company wallet (receives 30% of gift revenue)
COMPANY_WALLET_OWNER=company

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# -----------------------------------------------------------------------------
# Firebase Admin
# -----------------------------------------------------------------------------
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_WEB_API_KEY=AIza...
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# -----------------------------------------------------------------------------
# RapidAPI (Pornhub feed, trending, scraper)
# -----------------------------------------------------------------------------
RAPIDAPI_KEY=...
RAPIDAPI_HOST=pornhub2.p.rapidapi.com
RAPIDAPI_VIDEO_KEY=...
RAPIDAPI_VIDEO_HOST=pornhub2.p.rapidapi.com
RAPIDAPI_VIDEO_URL=https://pornhub2.p.rapidapi.com/v2/search?search=trending&page=1
RAPIDAPI_TRENDING_KEY=...
RAPIDAPI_TRENDING_HOST=pornhub-api-xnxx.p.rapidapi.com
RAPIDAPI_SCRAPER_KEY=...
RAPIDAPI_SCRAPER_HOST=pornhub-scraper-downloader.p.rapidapi.com
