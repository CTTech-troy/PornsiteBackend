# Firebase Admin service account (stringified JSON)
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_DATABASE_URL=
# Same Web API key as Firebase Console â†’ Project settings â†’ Web app (apiKey). Optional if VITE_FIREBASE_API_KEY is set in frontend.
FIREBASE_WEB_API_KEY=

# SMTP settings for sending verification emails
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_DOMAIN=
# Frontend URL used in verification link
FRONTEND_VERIFY_URL=
# Supabase
SUPABASE_URL=
# S3-compatible storage endpoint (for AWS SDK, rclone, etc.)
SUPABASE_STORAGE_S3_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_IMAGE_BUCKET=
SUPABASE_VIDEO_BUCKET=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=


# Admin secret for approving creators (keep secure)
ADMIN_SECRET=
# Server config
NODE_ENV=
PORT=

# -----------------------------------------------------------------------------
# RapidAPI â€“ Pornhub2 (stars, video feed, search)
# Get key: https://rapidapi.com/pornhub2-api-pornhub2-api-default/api/pornhub2
# -----------------------------------------------------------------------------
RAPIDAPI_KEY=
RAPIDAPI_HOST=
RAPIDAPI_URL=

# Video feed / trending (same host; use same key). URL can include query params for first page.
RAPIDAPI_VIDEO_KEY=
RAPIDAPI_VIDEO_HOST=
RAPIDAPI_VIDEO_URL=

# -----------------------------------------------------------------------------
# RapidAPI â€“ Trending + Search fallback (pornhub-api-xnxx)
# Used by: GET /api/videos/trending, and as fallback when scraper returns 429
# for GET /api/creators/:slug and GET /api/videos/search
# -----------------------------------------------------------------------------
RAPIDAPI_TRENDING_KEY=
RAPIDAPI_TRENDING_HOST=

# -----------------------------------------------------------------------------
# RapidAPI â€“ Pornhub Scraper (creator profile, video/pornstar search)
# Get key: https://rapidapi.com/.../api/pornhub-scraper-downloader
# -----------------------------------------------------------------------------
RAPIDAPI_SCRAPER_KEY=
RAPIDAPI_SCRAPER_HOST=
RAPIDAPI_SCRAPER_URL=
RAPIDAPI_SCRAPER_API_KEY=

# Frontend: in frontend/.env set VITE_API_URL=http://localhost:5000 so feed/trending use backend (keys stay on server).
