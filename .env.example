# Invite expiry (hours)
ADMIN_INVITE_EXPIRY_HOURS=1

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=XStreamVideos <support@xstreamvideos.site>

# Meilisearch (hybrid search)
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
MEILISEARCH_PUBLIC_HOST=
MEILISEARCH_SEARCH_API_KEY=
MEILISEARCH_VIDEOS_INDEX=videos
MEILISEARCH_CREATORS_INDEX=creators
MEILISEARCH_USERS_INDEX=users
MEILISEARCH_LIVE_STREAMS_INDEX=live_streams
MEILISEARCH_TAGS_INDEX=tags
MEILISEARCH_CATEGORIES_INDEX=categories

# Production-scale indexing
INDEXING_QUEUE_ENABLED=true
MAX_CONCURRENT_IMPORTS=5
SEARCH_SYNC_INTERVAL_MS=15000
SEARCH_SYNC_BATCH_SIZE=250
SEARCH_REINDEX_BATCH_SIZE=1000
MEILI_DOCUMENT_BATCH_SIZE=1000
SEARCH_INDEX_MAX_RETRIES=5
SEARCH_INDEX_LOCK_TIMEOUT_MS=600000

# Video import pipeline
BACKEND_PUBLIC_URL=https://pornsitebackend.onrender.com
IMPORT_STAGING_BUCKET=imports-staging
IMPORT_MAX_ARCHIVE_MB=2048
IMPORT_BATCH_SIZE=10000
