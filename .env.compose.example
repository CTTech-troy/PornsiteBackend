# Root orchestration variables for Docker Compose and deployment scripts.
# Service-specific variables live in backend/.env.example, frontend/.env.example,
# admin/.env.example, and ai/.env.example.

COMPOSE_PROJECT_NAME=xstream
NODE_ENV=development

BACKEND_PUBLIC_URL=http://localhost:5043
FRONTEND_PUBLIC_URL=http://localhost:5173
ADMIN_PUBLIC_URL=http://localhost:5174
AI_MODERATION_SERVICE_URL=http://ai-gateway:8000
PAYMENT_SERVICE_URL=http://payment-service:10000
PAYMENT_SERVICE_SHARED_SECRET=
PAYMENT_DEFAULT_PROVIDER=paystack
PAYMENT_NG_PROVIDER=monnify

# Upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
